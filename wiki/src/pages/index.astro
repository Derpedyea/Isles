---
import { guidePages } from "../data/wiki";
import WikiLayout from "../layouts/WikiLayout.astro";

const featuredPages = guidePages.filter((page) =>
	["getting-started", "center", "upgrades", "teams"].includes(page.slug),
);
---

<WikiLayout
	title="Mineperial Skyblock Wiki"
	description="A player guide for islands, teams, Center Shards, generator upgrades, PvP zones, and the shared dimensions."
	activeSlug=""
>
	<section class="band">
		<h2>Browse Game Content</h2>
	</section>

	<section class="browse-grid" aria-label="Browse wiki sections">
		{
			guidePages.map((card) => (
				<a class="browse-card search-card" href={`/${card.slug}/`} data-search={`${card.title} ${card.text} ${card.search}`}>
					<img class="mc-icon" src={card.icon} alt="" />
					<strong>{card.title}</strong>
					<small>{card.text}</small>
				</a>
			))
		}
	</section>

	<section class="band">
		<h2>Start Here</h2>
	</section>

	<article class="article search-card" data-search="home main page start island center shards generator upgrades teams commands">
		<header>
			<p>Main Page</p>
			<h2>Member Wiki</h2>
		</header>
		<div class="section-copy">
			<h3>A Player Guide</h3>
			<p>
				This wiki is for server members. It covers what to do in-game: how islands start,
				which commands matter, how teams share islands, where Center Shards come from,
				and what changes when the Nether or End unlocks.
			</p>
			<ul>
				<li>Use <code>/msb island</code> to find your island coordinates.</li>
				<li>Use <code>/msb upgrades</code> to improve your generator.</li>
				<li>Use <code>/team</code> to create or manage a shared island.</li>
			</ul>
		</div>
	</article>

	<section class="band">
		<h2>Popular Pages</h2>
	</section>

	<section class="feature-grid" aria-label="Popular wiki pages">
		{
			featuredPages.map((page) => (
				<section class="feature-card search-card" data-search={`${page.title} ${page.text} ${page.search}`}>
					<h3>{page.title}</h3>
					<p>{page.description}</p>
					<a href={`/${page.slug}/`}>Read {page.shortTitle}</a>
				</section>
			))
		}
	</section>
</WikiLayout>
