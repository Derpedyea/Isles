---
import { guidePages } from "../data/wiki";
import WikiLayout from "../layouts/WikiLayout.astro";

const featuredPages = guidePages.filter((page) =>
	["getting-started", "center", "upgrades", "teams"].includes(page.slug),
);
---

<WikiLayout
	title="Isles Wiki"
	description="A guide for islands, teams, Center Shards, generator upgrades, PvP zones, shared dimensions, and staff operations."
	activeSlug=""
>
	<section class="band">
		<h2>Browse Game Content</h2>
	</section>

	<section class="browse-grid" aria-label="Browse wiki sections">
		{
			guidePages.map((card) => (
				<a class="browse-card search-card" href={`/${card.slug}/`} data-search={`${card.title} ${card.text} ${card.search}`}>
					<img class="mc-icon" src={card.icon} alt="" />
					<strong>{card.title}</strong>
					<small>{card.text}</small>
				</a>
			))
		}
	</section>

	<section class="band">
		<h2>Start Here</h2>
	</section>

	<article class="article search-card" data-search="home main page start island center shards generator upgrades teams commands">
		<header>
			<p>Main Page</p>
			<h2>Server Wiki</h2>
		</header>
		<div class="section-copy">
			<h3>Player And Staff Guide</h3>
			<p>
				This wiki covers what to do in-game and how the current Isles plugin is operated:
				how islands start, which commands matter, how teams share islands, where Center Shards
				come from, what changes when the Nether or End unlocks, and which tools staff use for
				resets and maintenance.
			</p>
			<ul>
				<li>Use <code>/isles island</code> to find your island coordinates.</li>
				<li>Use <code>/isles upgrades</code> to improve your generator.</li>
				<li>Use <code>/team</code> to create or manage a shared island.</li>
				<li>Use the Staff Tools page for admin-only reset, unlock, and diagnostic commands.</li>
			</ul>
		</div>
	</article>

	<section class="band">
		<h2>Popular Pages</h2>
	</section>

	<section class="feature-grid" aria-label="Popular wiki pages">
		{
			featuredPages.map((page) => (
				<section class="feature-card search-card" data-search={`${page.title} ${page.text} ${page.search}`}>
					<h3>{page.title}</h3>
					<p>{page.description}</p>
					<a href={`/${page.slug}/`}>Read {page.shortTitle}</a>
				</section>
			))
		}
	</section>
</WikiLayout>
